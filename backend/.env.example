# Postgres (Railway provides DATABASE_URL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meridian
# HTTP
PORT=3000
# Chain (used by later plans)
RHC_RPC_URL=https://rpc.testnet.robinhood.example
CHAIN_ID=46630
# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LOG_LEVEL=info
NODE_ENV=development
# --- Chain (Plan B) ---
MULTICALL3_ADDRESS=0xcA11bde05977b3631167028862bE2a173976CA11
KEEPER_PRIVATE_KEY=
# --- Signals (Plan B) ---
CHAINLINK_DS_API_URL=https://api.dataengine.chain.link
CHAINLINK_DS_API_KEY=
CHAINLINK_DS_API_SECRET=
PYTH_HERMES_URL=https://hermes.pyth.network
# seconds; a reading older than this is treated as stale
SIGNAL_STALE_THRESHOLD_SECONDS=120
# seconds after L2 sequencer recovery before on-chain feeds are trusted
SEQUENCER_GRACE_PERIOD_SECONDS=3600
# basis points of NAV added to the confidence band when a reading is estimated
ESTIMATED_BAND_BPS=200
# --- Forward cash (L5) ---
# JSON map of vaultAddress -> forwardCashQueueAddress; empty until L5 deploy.
FORWARD_QUEUES={}
# Forward Operator (keeper + AP). Disabled by default; needs its own funded signer.
FORWARD_OPERATOR_ENABLED=false
FORWARD_OPERATOR_PRIVATE_KEY=
# Testnet MockAPFiller the operator drives as the AP; prod APFiller is a contracts follow-up.
FORWARD_AP_FILLER_ADDRESS=
# Out of scope (flagged): production APFiller contract, real AP liquidity sourcing (DEX/CEX),
# separate keeper vs AP operator keys, live e2e (needs L5 deploy + deployer key).
# --- Suggested-funds catalog (create-flow recommender) ---
# Override the path to tools/registry/out/suggested_funds.json (auto-resolved when unset).
SUGGESTED_FUNDS_PATH=
# JSON array of lowercased on-chain token addresses; a catalog fund pre-fills the wizard only when
# its constituents are in this set. Empty on testnet (only ~5 demo tokens) → reference-only.
SUGGESTED_FUNDS_TOKENS=[]
