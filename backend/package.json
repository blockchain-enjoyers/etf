{
  "name": "@meridian/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=.env --import ./dist/otel.js dist/main.js",
    "dev": "node --env-file=.env --import ./src/otel.ts --watch src/main.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "test": "node ./scripts/run-vitest.mjs run --project unit",
    "test:int": "node ./scripts/run-vitest.mjs run --project integration",
    "test:watch": "node ./scripts/run-vitest.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "db:seed": "node --env-file=.env scripts/run-seed.mjs"
  },
  "dependencies": {
    "@chainlink/contracts": "1.2.0",
    "@chainlink/data-streams-sdk": "^1.2.1",
    "@fastify/cors": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "@meridian/contracts": "workspace:^",
    "@meridian/sdk": "workspace:^",
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-fastify": "^11.1.24",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@openzeppelin/merkle-tree": "^1.0.8",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/instrumentation": "^7.8.0",
    "@pythnetwork/hermes-client": "^3.1.0",
    "cockatiel": "^4.0.0",
    "nestjs-otel": "^8.0.3",
    "nestjs-pino": "^4.6.1",
    "nestjs-zod": "^5.4.0",
    "pg": "^8.19.0",
    "pg-boss": "^12.18.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "viem": "^2.52.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@fastify/otel": "^0.18.1",
    "@meridian/config": "workspace:^",
    "@nestjs/testing": "^11.1.24",
    "@prisma/config": "^7.8.0",
    "@swc/core": "^1.7.0",
    "@testcontainers/postgresql": "^12.0.1",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.0",
    "eslint": "^9.0.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.0.0",
    "unplugin-swc": "^1.5.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.8"
  }
}
